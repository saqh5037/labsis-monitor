# Labsis Monitor — Configuración por cliente
# Copiar a .env y ajustar valores

# Servidor
PORT=3090
BIND_HOST=0.0.0.0

# Modo local: "all" si el monitor corre en el mismo server que Labsis
# Para LAPI: "el18" (corre en El 18, lee local + SSH a El 3)
LOCAL_SERVER=all

# PostgreSQL
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=labsis
PG_USER=labsis
PG_PASSWORD=
PG_SSL=false

# Servidores a monitorear (JSON)
# Cada servidor tiene: host, name, labsisCSV, y opcionalmente rdsCSV, slowLog, locksLog, idleTxLog
MONITOR_SERVERS={"server1":{"host":"127.0.0.1","name":"Mi Servidor","labsisCSV":"/tmp/labsis-monitor.csv"}}

# Mapeo IP → nombre (para queries de pg_stat_activity)
SERVER_NAME_MAP={"127.0.0.1":"Mi Servidor"}

# Nombre del sitio (aparece en el frontend)
SITE_NAME=Mi Laboratorio

# SSH (solo si se monitorean servidores remotos)
# SSH_KEY_PATH=/path/to/key.pem
# SSH_USER=dynamtek
